# SwellSwap environment variables
# Copy this file to .env and fill in your real values

# Supabase Postgres connection string (Settings → Database → Connection pooling URI)
# Replace [YOUR-PASSWORD] with your actual database password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.tsirrgdblzsdkwwfyhfu.supabase.co:5432/postgres

# JWT signing secret (use any long random string in production)
JWT_SECRET=swellswap-change-this-in-production

# Web Push VAPID keys (optional — defaults are baked in for demo)
# VAPID_PUBLIC=
# VAPID_PRIVATE=
